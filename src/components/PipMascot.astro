---
// @zero:hidden
interface Props {
  scale?: number;
  cheeks?: boolean;
}
const { scale = 1, cheeks = true }: Props = Astro.props;
---

<div class="mascot" style={`--s:${scale}`} aria-hidden="true">
  <div class="scaler">
    <div class="bob">
      <div class="body"></div>
      <div class="eyes">
        <span></span><span></span>
      </div>
      <div class="smile"></div>
      {cheeks && <div class="cheek left" />}
      {cheeks && <div class="cheek right" />}
      <div class="tuft"></div>
    </div>
  </div>
</div>

<style>
  .mascot {
    width: calc(130px * var(--s));
    height: calc(150px * var(--s));
  }
  .scaler {
    transform: scale(var(--s));
    transform-origin: top left;
  }
  .bob {
    position: relative;
    width: 130px;
    height: 150px;
    animation: pipbob 4s ease-in-out infinite;
  }
  .body {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 110px;
    height: 126px;
    background: #fff;
    border-radius: 50% 50% 46% 46% / 58% 58% 42% 42%;
    box-shadow: inset 0 -10px 0 rgba(43, 38, 34, 0.04);
  }
  .eyes {
    position: absolute;
    top: 34px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 22px;
  }
  .eyes span {
    width: 11px;
    height: 11px;
    background: #2b2622;
    border-radius: 50%;
  }
  .smile {
    position: absolute;
    top: 50px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 8px;
    border-bottom: 3px solid var(--accent, #ff6a3d);
    border-radius: 0 0 12px 12px;
  }
  .cheek {
    position: absolute;
    top: 52px;
    width: 16px;
    height: 16px;
    background: var(--accent-soft, #ffe1d3);
    border-radius: 50%;
    opacity: 0.8;
  }
  .cheek.left {
    left: 22px;
  }
  .cheek.right {
    right: 22px;
  }
  .tuft {
    position: absolute;
    top: -6px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 9px solid transparent;
    border-right: 9px solid transparent;
    border-bottom: 20px solid #fff;
  }
</style>
