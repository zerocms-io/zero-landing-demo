---
// @zero:hidden
interface Props {
  stats: {
    header: { eyebrow: string; title: string };
    items: { value: string; label: string }[];
  };
}
const { stats } = Astro.props;
---

<section class="stats">
  <div class="inner">
    <div class="head">
      <p class="eyebrow">{stats.header.eyebrow}</p>
      <h2>{stats.header.title}</h2>
    </div>
    <div class="grid">
      {
        stats.items.map((s) => (
          <div class="card">
            <p class="value">{s.value}</p>
            <p class="label">{s.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .stats {
    background: #211e1b;
    color: #fdf7ec;
    padding: 92px 0;
  }
  .inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .head {
    text-align: center;
    max-width: 620px;
    margin: 0 auto 56px;
  }
  .eyebrow {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent, #ff6a3d);
    margin-bottom: 14px;
  }
  .head h2 {
    font-size: clamp(34px, 4.5vw, 48px);
    color: #fdf7ec;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .card {
    text-align: center;
    border: 1px solid rgba(253, 247, 236, 0.12);
    border-radius: 24px;
    padding: 38px 24px;
  }
  .value {
    font-family: "Bricolage Grotesque", system-ui, sans-serif;
    font-weight: 800;
    font-size: 62px;
    color: var(--accent, #ff6a3d);
    line-height: 1;
  }
  .label {
    font-size: 15.5px;
    color: #c9c0b4;
    margin-top: 10px;
    line-height: 1.4;
  }
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
