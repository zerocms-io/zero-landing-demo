---
// @zero:hidden
interface Props {
  how: {
    header: { eyebrow: string; title: string };
    steps: { number: number; title: string; body: string }[];
  };
}
const { how } = Astro.props;
---

<section id="how" class="how">
  <div class="inner">
    <div class="head">
      <p class="eyebrow">{how.header.eyebrow}</p>
      <h2>{how.header.title}</h2>
    </div>
    <div class="grid">
      {
        how.steps.map((s) => (
          <div class="card">
            <span class="num">{s.number}</span>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .how {
    background: #e7f5ec;
    padding: 88px 0;
    margin-top: 40px;
  }
  .inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .head {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 52px;
  }
  .eyebrow {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #1e7a4e;
    margin-bottom: 14px;
  }
  .head h2 {
    font-size: clamp(34px, 4.5vw, 50px);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .card {
    background: #fff;
    border-radius: 26px;
    padding: 32px;
  }
  .num {
    font-family: "Bricolage Grotesque", system-ui, sans-serif;
    font-weight: 800;
    font-size: 22px;
    color: #fff;
    background: var(--accent, #ff6a3d);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: grid;
    place-items: center;
  }
  h3 {
    font-size: 23px;
    margin-top: 20px;
  }
  p {
    font-size: 15.5px;
    color: #5c554d;
    line-height: 1.55;
    margin-top: 10px;
  }
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
