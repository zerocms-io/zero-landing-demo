---
// @zero:hidden
import { getEntry } from "astro:content";
import PipMascot from "../PipMascot.astro";

interface Item {
  title: string;
  body: string;
  icon: string;
  colSpan: number;
  rowSpan: number;
  tone: "white" | "accent" | "cream";
  illustration: "bars" | "mascot" | "nudge" | "growth" | "routines" | "none";
  items?: string[];
}
interface Props {
  features: { header: { eyebrow: string; title: string }; items: Item[] };
}
const { features } = Astro.props;
const settings = await getEntry("settings", "general");
const showMascot = settings!.data.theme.showMascot;
const barHeights = [40, 62, 30, 78, 54];
---

<section id="features" class="features">
  <div class="head">
    <p class="eyebrow">{features.header.eyebrow}</p>
    <h2 set:html={features.header.title} />
  </div>
  <div class="grid">
    {
      features.items.map((f) => {
        const split =
          f.illustration === "bars" || f.illustration === "routines";
        return (
          <article
            class:list={[
              "tile",
              `tone-${f.tone}`,
              { split, column: f.illustration === "mascot" },
            ]}
            style={`grid-column:span ${f.colSpan};grid-row:span ${f.rowSpan}`}
          >
            <div class="content">
              <span class:list={["icon", `ic-${f.illustration}`]}>
                {f.icon}
              </span>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>

            {f.illustration === "bars" && (
              <div class="art bars">
                {barHeights.map((h, i) => (
                  <span class:list={{ dim: i === 2 }} style={`height:${h}px`} />
                ))}
              </div>
            )}

            {f.illustration === "mascot" && showMascot && (
              <div class="art mascot">
                <PipMascot />
              </div>
            )}

            {f.illustration === "routines" && f.items && (
              <div class="art chips">
                {f.items.map((chip, i) => (
                  <span style={i === 1 ? "margin-left:20px" : ""}>{chip}</span>
                ))}
              </div>
            )}
          </article>
        );
      })
    }
  </div>
</section>

<style>
  .features {
    max-width: 1180px;
    margin: 0 auto;
    padding: 64px 32px;
  }
  .head {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 48px;
  }
  .eyebrow {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-ink, #c63f1b);
    margin-bottom: 14px;
  }
  .head h2 {
    font-size: clamp(34px, 4.5vw, 50px);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: minmax(0, auto);
    gap: 20px;
  }
  .tile {
    border-radius: 28px;
    padding: 34px;
  }
  .tone-white {
    background: #fff;
    border: 1px solid rgba(43, 38, 34, 0.08);
    box-shadow: 0 14px 40px -22px rgba(43, 38, 34, 0.3);
  }
  .tone-accent {
    background: var(--accent, #ff6a3d);
    color: #fff;
    box-shadow: 0 16px 40px -18px var(--accent, #ff6a3d);
  }
  .tone-cream {
    background: #fdefc9;
  }

  .split {
    display: flex;
    gap: 28px;
    align-items: center;
  }
  .split .content {
    flex: 1;
  }
  .column {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .icon {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: 16px;
    font-size: 22px;
    margin-bottom: 18px;
    background: var(--accent-soft, #ffe1d3);
  }
  .ic-mascot {
    background: rgba(255, 255, 255, 0.22);
  }
  .ic-nudge {
    background: #e9ecff;
  }
  .ic-growth {
    background: #e7f5ec;
  }
  .ic-routines {
    background: #fff;
  }
  h3 {
    font-size: 24px;
  }
  .tone-white h3,
  .tone-cream h3 {
    font-size: 22px;
  }
  .tile p {
    font-size: 15.5px;
    line-height: 1.55;
    margin-top: 10px;
  }
  .tone-white p {
    color: #5c554d;
  }
  .tone-accent p {
    opacity: 0.94;
  }
  .tone-cream p {
    color: #6b5f3f;
  }

  .art.bars {
    display: flex;
    gap: 6px;
    align-items: flex-end;
    width: 180px;
    height: 150px;
    justify-content: center;
    border-radius: 20px;
    background: linear-gradient(135deg, var(--accent-soft, #ffe1d3), #fff);
    border: 1px solid rgba(43, 38, 34, 0.06);
  }
  .art.bars span {
    width: 14px;
    border-radius: 6px;
    background: var(--accent, #ff6a3d);
  }
  .art.bars span.dim {
    background: rgba(43, 38, 34, 0.14);
  }
  .art.mascot {
    display: flex;
    justify-content: center;
    margin-top: 20px;
  }
  .art.chips {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 190px;
  }
  .art.chips span {
    background: #fff;
    border-radius: 12px;
    padding: 10px 14px;
    font-size: 14px;
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .tile {
      grid-column: span 1 !important;
      grid-row: span 1 !important;
    }
    /* Stack side-by-side tiles so the heading gets full width instead of a
       cramped column next to the illustration. */
    .split {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }
    .art.bars,
    .art.chips {
      width: 100%;
    }
  }
</style>
