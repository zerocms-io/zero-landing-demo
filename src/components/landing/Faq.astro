---
// @zero:hidden
interface Props {
  faq: {
    header: { eyebrow: string; title: string };
    items: { question: string; answer: string; defaultOpen?: boolean }[];
  };
}
const { faq } = Astro.props;
---

<section id="faq" class="faq">
  <div class="head">
    <p class="eyebrow">{faq.header.eyebrow}</p>
    <h2>{faq.header.title}</h2>
  </div>
  <div class="list">
    {
      faq.items.map((item) => (
        <details open={item.defaultOpen}>
          <summary>
            {item.question}
            <span class="plus">+</span>
          </summary>
          <p>{item.answer}</p>
        </details>
      ))
    }
  </div>
</section>

<style>
  .faq {
    max-width: 820px;
    margin: 0 auto;
    padding: 92px 32px;
  }
  .head {
    text-align: center;
    margin-bottom: 44px;
  }
  .eyebrow {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-ink, #c63f1b);
    margin-bottom: 14px;
  }
  .head h2 {
    font-size: clamp(32px, 4.5vw, 46px);
  }
  .list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  details {
    background: #fff;
    border: 1px solid rgba(43, 38, 34, 0.09);
    border-radius: 20px;
    padding: 6px 24px;
  }
  summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 0;
    font-family: "Bricolage Grotesque", system-ui, sans-serif;
    font-weight: 700;
    font-size: 19px;
  }
  .plus {
    color: var(--accent, #ff6a3d);
    font-size: 24px;
    font-weight: 800;
    transition: transform 0.2s;
  }
  details[open] .plus {
    transform: rotate(45deg);
  }
  details p {
    font-size: 15.5px;
    color: #5c554d;
    line-height: 1.6;
    padding: 0 0 20px;
  }
</style>
