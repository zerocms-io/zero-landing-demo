---
---

<div class="check">
  <span class="box">✓</span>
  <div class="text"><slot /></div>
</div>

<style>
  .check {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .box {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: 8px;
    background: #2fa36b;
    display: grid;
    place-items: center;
    color: #fff;
    font-size: 14px;
    font-weight: 800;
  }
  .text {
    font-size: 16px;
    color: #2f5a43;
    font-weight: 500;
  }
  /* If the editor writes block content, neutralise the wrapping paragraph */
  .text :global(p) {
    margin: 0;
    font: inherit;
    color: inherit;
  }
</style>
