---
interface Props {
  hero: { badge: string; title: string; body: string };
}
const { hero } = Astro.props;
const m = hero.title.match(/^(.*)\{(.+?)\}(.*)$/);
const parts = m ? { before: m[1], hl: m[2], after: m[3] } : null;
---

<section class="hero">
  <span class="blob"></span>
  <div class="inner">
    <span class="badge"><span class="dot"></span>{hero.badge}</span>
    <h1>
      {
        parts ? (
          <>
            {parts.before}
            <span class="hl">{parts.hl}</span>
            {parts.after}
          </>
        ) : (
          hero.title
        )
      }
    </h1>
    <p>{hero.body}</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    max-width: 1180px;
    margin: 0 auto;
    padding: 80px 32px 44px;
    text-align: center;
  }
  .blob {
    position: absolute;
    top: 60px;
    left: 50%;
    transform: translateX(-50%);
    width: 340px;
    height: 280px;
    background: var(--accent-soft, #ffe1d3);
    border-radius: 50%;
    filter: blur(10px);
    opacity: 0.5;
    z-index: 0;
  }
  .inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1px solid rgba(43, 38, 34, 0.1);
    padding: 7px 14px 7px 10px;
    border-radius: 999px;
    font-size: 13.5px;
    font-weight: 600;
    box-shadow: 0 3px 12px rgba(43, 38, 34, 0.06);
  }
  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent, #ff6a3d);
  }
  h1 {
    font-size: clamp(42px, 6vw, 68px);
    margin: 22px 0 0;
    line-height: 0.98;
  }
  p {
    font-size: 20px;
    line-height: 1.5;
    color: #5c554d;
    max-width: 560px;
    margin: 24px auto 0;
  }
</style>
