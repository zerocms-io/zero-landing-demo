---
interface Props {
  eyebrow: string;
  title: string;
  lead: string;
}
const { eyebrow, title, lead } = Astro.props;
---

<section class="head">
  <span class="blob"></span>
  <div class="inner">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="lead">{lead}</p>
  </div>
</section>

<style>
  .head {
    position: relative;
    max-width: 1180px;
    margin: 0 auto;
    padding: 72px 32px 24px;
    text-align: center;
  }
  .blob {
    position: absolute;
    top: 40px;
    left: 50%;
    transform: translateX(-50%);
    width: 320px;
    height: 240px;
    background: var(--accent-soft, #ffe1d3);
    border-radius: 50%;
    filter: blur(10px);
    opacity: 0.5;
    z-index: 0;
  }
  .inner {
    position: relative;
    z-index: 1;
    max-width: 640px;
    margin: 0 auto;
  }
  .eyebrow {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-ink, #c63f1b);
    margin-bottom: 14px;
  }
  h1 {
    font-size: clamp(40px, 6vw, 60px);
  }
  .lead {
    font-size: 19px;
    color: #5c554d;
    line-height: 1.5;
    margin: 20px auto 0;
    max-width: 500px;
  }
</style>
