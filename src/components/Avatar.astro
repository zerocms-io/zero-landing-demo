---
// @zero:hidden
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { resolveAvatarColor, type AvatarColor } from "../lib/palette";

interface Props {
  avatar?: ImageMetadata;
  initials: string;
  color: AvatarColor;
  name?: string;
  fontSize: number;
}
const { avatar, initials, color, name, fontSize }: Props = Astro.props;
const { bg, ink } = resolveAvatarColor(color);
---

<span
  class="avatar-inner"
  style={`background:${bg};color:${ink};font-size:${fontSize}px`}
>
  {
    avatar ? (
      <Image
        src={avatar}
        alt={name ?? initials}
        width={200}
        height={200}
        class="img"
      />
    ) : (
      initials
    )
  }
</span>

<style>
  /* Fills its parent; the parent owns size, border-radius, border and margin.
     border-radius: inherit + overflow: hidden clips the photo to the parent shape. */
  .avatar-inner {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    overflow: hidden;
    font-family: "Bricolage Grotesque", system-ui, sans-serif;
    font-weight: 800;
    line-height: 1;
  }
  .img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
