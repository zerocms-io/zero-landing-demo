---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TeamHero from '../components/team/TeamHero.astro';
import Values from '../components/team/Values.astro';
import Leadership from '../components/team/Leadership.astro';
import TeamGrid from '../components/team/TeamGrid.astro';
import OpenRoles from '../components/team/OpenRoles.astro';
import CtaBand from '../components/CtaBand.astro';

const page = await getEntry('teamPage', 'team');
const d = page!.data;
---

<BaseLayout
  title="Pip — The team"
  description="The tiny, remote-first team building the gentlest way to keep a habit."
>
  <TeamHero hero={d.hero} />
  <Values values={d.values} />
  <Leadership eyebrow={d.leadershipEyebrow} />
  <TeamGrid eyebrow={d.flockEyebrow} hiringCard={d.hiringCard} />
  <OpenRoles roles={d.roles} />
  <section class="cta-wrap">
    <CtaBand
      title={d.cta.title}
      body={d.cta.body}
      buttons={d.cta.buttons}
      variant={d.cta.variant}
      showMascot={d.cta.showMascot}
    />
  </section>
</BaseLayout>

<style>
  .cta-wrap {
    max-width: 1180px;
    margin: 0 auto 80px;
    padding: 0 32px;
  }
</style>
