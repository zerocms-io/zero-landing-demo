---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/landing/Hero.astro';
import PressMarquee from '../components/landing/PressMarquee.astro';
import FeaturesBento from '../components/landing/FeaturesBento.astro';
import HowItWorks from '../components/landing/HowItWorks.astro';
import StatsBand from '../components/landing/StatsBand.astro';
import Testimonials from '../components/landing/Testimonials.astro';
import TeamTeaser from '../components/landing/TeamTeaser.astro';
import Faq from '../components/landing/Faq.astro';
import LearnCards from '../components/landing/LearnCards.astro';
import CtaBand from '../components/mdx/CtaBand.astro';

const home = await getEntry('home', 'home');
const d = home!.data;
---

<BaseLayout title="Pip — Tiny habits, big good days">
  <Hero hero={d.hero} />
  <PressMarquee press={d.press} />
  <FeaturesBento features={d.features} />
  <HowItWorks how={d.how} />
  <StatsBand stats={d.stats} />
  <Testimonials testimonials={d.testimonials} />
  <TeamTeaser teamTeaser={d.teamTeaser} />
  <Faq faq={d.faq} />
  <LearnCards learn={d.learn} />
  <section id="cta" class="cta-wrap">
    <CtaBand
      title={d.cta.title}
      buttons={d.cta.buttons}
      variant={d.cta.variant}
      showMascot={d.cta.showMascot}
    >
      {d.cta.body}
    </CtaBand>
  </section>
</BaseLayout>

<style>
  .cta-wrap {
    max-width: 1180px;
    margin: 88px auto 80px;
    padding: 0 32px;
  }
</style>
